#. Display status
#: ../src/main.c:306
msgid "Starting CDEmu daemon with following parameters:"
msgstr "Se pornește demonul CDEmu cu următorii parametri:"

#: ../src/main.c:308
#, c-format
msgid " - config file: %s (exists: %d)"
msgstr " - fișier de configurare: %s (există: %d)"

#: ../src/main.c:310
msgid " - config file: N/A"
msgstr " - fișier de configurare: Indisp."

#: ../src/main.c:312
#, c-format
msgid " - num devices: %i"
msgstr " - număr dispozitive: %i"

#: ../src/main.c:313
#, c-format
msgid " - control device: %s"
msgstr " - dispozitiv de control: %s"

#: ../src/main.c:314
#, c-format
msgid " - audio driver: %s"
msgstr " - driver audio: %s"

#: ../src/main.c:315
#, c-format
msgid " - bus type: %s"
msgstr " - tip de magistrală: %s"

#: ../src/main.c:316
#, c-format
msgid " - default CDEmu debug mask: 0x%X"
msgstr " - mască implicită de depanare CDEmu: 0x%X"

#: ../src/main.c:317
#, c-format
msgid " - default libMirage debug mask: 0x%X"
msgstr " - mască implicită de depanare libMirage: 0x%X"

#: ../src/main.c:318
#, c-format
msgid " - enable system sleep handler: %d"
msgstr " - activează manipulantul pentru adormirea sistemului: %d"

#: ../src/main.c:326
#, c-format
msgid "Invalid bus argument '%s', using default bus!"
msgstr ""
"Argument eronat „%s” pentru magistrală, se folosește magistrala implicită!"

#: ../src/main.c:342
msgid ""
"WARNING: using CDEmu on system bus is deprecated and might lead to security "
"issues on multi-user systems! Consult the README file for more details."
msgstr ""
"ATENȚIE: folosirea CDEmu pe magistrala sistemului e învechită și poate cauza "
"probleme de securitate pe sisteme cu utilizatori multipli! Consultați "
"fișierul README pentru detalii suplimentare."

#: ../src/main.c:350
msgid "Failed to add signal handler for SIGTERM!"
msgstr "Adăugarea manipulantului de semnale pentru SIGTERM a eșuat!"

#: ../src/main.c:353
msgid "Failed to add signal handler for SIGINT!"
msgstr "Adăugarea manipulantului de semnale pentru SIGINT a eșuat!"

#: ../src/main.c:357
msgid "Failed to add signal handler for SIGHUP!"
msgstr "Adăugarea manipulantului de semnale pentru SIGHUP a eșuat!"

