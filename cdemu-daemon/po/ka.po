msgstr "პარამეტრების დამუშავების შეცდომა: %s"

#: ../src/main.c:160
#, c-format
msgid "Failed to load config file '%s': %s"
msgstr "ჩატვირთვის შეცდომა კონფიგურაციის ფაილისთვის '%s': %s"

#: ../src/main.c:289
#, c-format
msgid "Failed to open log file %s for writing!"
msgstr "ჟურნალის ფაილის %s ჩასაწერად გახსნის შეცდომა!"

#: ../src/main.c:297
#, c-format
msgid "Failed to initialize libMirage: %s!"
msgstr "libMirage-ის ინიციალიზაცია ჩავარდა: %s!"

#. Display status
#: ../src/main.c:306
msgid "Starting CDEmu daemon with following parameters:"
msgstr "CDEmu-ის დემონის გაშვება შემდეგი პარამეტრებით:"

#: ../src/main.c:308
#, c-format
msgid " - config file: %s (exists: %d)"
msgstr " - კონფიგურაციის ფაილი: %s (არსებობს: %d)"

#: ../src/main.c:310
msgid " - config file: N/A"
msgstr " - კონფიგურაციის ფაილი: N/A"

#: ../src/main.c:312
#, c-format
msgid " - num devices: %i"
msgstr " - მოწყობილობების რ-ბა: %i"

#: ../src/main.c:313
#, c-format
msgid " - control device: %s"
msgstr " - კონტროლის მოწყობილობა: %s"

#: ../src/main.c:314
#, c-format
msgid " - audio driver: %s"
msgstr " - აუდიოდრაივერი: %s"

#: ../src/main.c:315
#, c-format
msgid " - bus type: %s"
msgstr " - სალტეს ტიპი: %s"

#: ../src/main.c:316
#, c-format
msgid " - default CDEmu debug mask: 0x%X"
msgstr " - ნაგულისხმევი CDEmu-ის გამართვის ნიღაბი: 0x%X"

#: ../src/main.c:317
#, c-format
msgid " - default libMirage debug mask: 0x%X"
msgstr " - ნაგულისხმევი libMirage-ის გამართვის ნიღაბი: 0x%X"

#: ../src/main.c:318
#, c-format
msgid " - enable system sleep handler: %d"
msgstr " - სისტემის ძილის დამმუშავებლის ჩართვა: %d"

#: ../src/main.c:326
#, c-format
msgid "Invalid bus argument '%s', using default bus!"
msgstr "არასწორი სალტეს არგუმენტი '%s'. გამოიყენება ნაგულისხმევი სალტე!"

#: ../src/main.c:342
msgid ""
"WARNING: using CDEmu on system bus is deprecated and might lead to security "
"issues on multi-user systems! Consult the README file for more details."
msgstr ""
"გაფრთხილება: CDEmu-ის სისტემურ სალტეზე გამოყენება მოძველებულია და შეიძლება, "
"უსაფრთხოების პრობლემებამდე მიგიყვანოთ მრავალმომხმარებლიან სისტემაზე! მეტი "
"დეტალებისთვის იხილეთ ფაილი README."

#: ../src/main.c:350
msgid "Failed to add signal handler for SIGTERM!"
msgstr "სიგნალის დამმუშავებლის დამატების შეცდომა სიგნალისთვის SIGTERM!"

#: ../src/main.c:353
msgid "Failed to add signal handler for SIGINT!"
msgstr "სიგნალის დამმუშავებლის დამატების შეცდომა სიგნალისთვის SIGINT!"

#: ../src/main.c:357
msgid "Failed to add signal handler for SIGHUP!"
msgstr "სიგნალის დამმუშავებლის დამატების შეცდომა სიგნალისთვის SIGHUP!"

#. Printed when daemon stops
#: ../src/main.c:363
msgid "Stopping daemon."
msgstr "დემონი ჩერდება."

#: ../src/main.c:365
msgid "Daemon initialization and start failed!"
msgstr "დემონის ინიციალიზაცია და გაშვება ჩავარდა!"
