msgstr "Napaka pri odstranjevanju naprave!"

#: ../src/daemon-dbus.c:481
#, c-format
msgid "Invalid method name '%s'!"
msgstr "Neveljavno ime metode '%s'!"

#: ../src/main.c:58
#, c-format
msgid "Failed to read integer (%s:%s) from config: %s"
msgstr "Napaka pri branju številke (%s:%s) iz nastavitvene datoteke: %s"

#: ../src/main.c:75
#, c-format
msgid "Failed to read string (%s:%s) from config: %s"
msgstr "Napaka pri branju znakovnega niza (%s:%s) iz nastavitvene datoteke: %s"

#: ../src/main.c:108
msgid "Config file"
msgstr "Datoteka z nastavitvami"

#: ../src/main.c:108
msgid "filename"
msgstr "ime-datoteke"

#: ../src/main.c:109
msgid "Number of devices"
msgstr "Število naprav"

#: ../src/main.c:109
msgid "N"
msgstr "N"

#: ../src/main.c:110
msgid "Control device"
msgstr "Kontrolna naprava"

#: ../src/main.c:110
msgid "path"
msgstr "pot-do-naprave"

#: ../src/main.c:111
msgid "Audio driver"
msgstr "Avdio gonilnik"

#: ../src/main.c:111
msgid "driver"
msgstr "gonilnik"

#: ../src/main.c:112
msgid "Bus type to use"
msgstr "Vrsta vodila"

#: ../src/main.c:112
msgid "bus_type"
msgstr "vrsta-vodila"

#: ../src/main.c:113
msgid "Logfile"
msgstr "Datoteka z dnevnikom"

#: ../src/main.c:113
msgid "logfile"
msgstr "ime-datoteke"

#: ../src/main.c:114
msgid "Default debug mask for CDEmu devices"
msgstr "Privzeta razhroščevalna maska za naprave CDEmu"

#: ../src/main.c:114 ../src/main.c:115
msgid "mask"
msgstr "maska"

#: ../src/main.c:115
msgid "Default debug mask for underlying libMirage"
msgstr "Privzeta razhroščevalna maska za knjižnico libMirage"

#: ../src/main.c:116
msgid ""
"Enable system sleep handler to stop devices before system enters suspend/"
"hibernation (0=disable, 1=enable)"
msgstr ""
"Vklop podpore za zaustavljanje naprav ob vstopu sistema v stanje spanja/"
"hibernacije (0=izključi, 1=vključi)"

#: ../src/main.c:143
#, c-format
msgid "Failed to parse options: %s"
msgstr "Napaka pri branju argumentorv: %s"

#: ../src/main.c:160
#, c-format
msgid "Failed to load config file '%s': %s"
msgstr "Napaka pri branju datoteke z nastavitvami '%s': %s"

#: ../src/main.c:289
#, c-format
msgid "Failed to open log file %s for writing!"
msgstr "Napaka pri odpiranju datoteke z dnevnikom %s za pisanje!"

#: ../src/main.c:297
#, c-format
msgid "Failed to initialize libMirage: %s!"
msgstr "Napaka pri inicializaciji knjižnice libMirage: %s!"

#. Display status
#: ../src/main.c:306
msgid "Starting CDEmu daemon with following parameters:"
msgstr "Zaganjam CDEmu demon z naslednjimi nastavitvami:"

#: ../src/main.c:308
#, c-format
msgid " - config file: %s (exists: %d)"
msgstr " - datoteka z nastavitvami: %s (obstaja: %d)"

#: ../src/main.c:310
msgid " - config file: N/A"
msgstr " - datoteka z nastavitvami: ni podana"

#: ../src/main.c:312
#, c-format
msgid " - num devices: %i"
msgstr " - število naprav: %i"

#: ../src/main.c:313
#, c-format
msgid " - control device: %s"
msgstr " - kontrolna naprava: %s"

#: ../src/main.c:314
#, c-format
msgid " - audio driver: %s"
msgstr " - avdio gonilnik: %s"

#: ../src/main.c:315
#, c-format
msgid " - bus type: %s"
msgstr " - vrsta vodila: %s"

#: ../src/main.c:316
#, c-format
msgid " - default CDEmu debug mask: 0x%X"
msgstr " - privzeta razhroščevalna maska za naprave CDEmu: 0x%X"

#: ../src/main.c:317
#, c-format
msgid " - default libMirage debug mask: 0x%X"
msgstr " - privzeta razhroščevalna maska za knjižnico libMirage: 0x%X"

#: ../src/main.c:318
#, c-format
msgid " - enable system sleep handler: %d"
msgstr " - podpora za spanje/hibernacijo sistema: %d"

#: ../src/main.c:326
#, c-format
msgid "Invalid bus argument '%s', using default bus!"
msgstr "Neveljavna vrsta vodila '%s', uporabljeno bo privzeto vodilo!"

#: ../src/main.c:342
msgid ""
"WARNING: using CDEmu on system bus is deprecated and might lead to security "
"issues on multi-user systems! Consult the README file for more details."
msgstr ""
"OPOZORILO: uporaba CDEmu na sistemskem vodilu je opuščena in lahko privede "
"do težav z varnostjo na več-uporabniških sistemih! Za več informacij "
"preberite README datoteko."

#: ../src/main.c:350
msgid "Failed to add signal handler for SIGTERM!"
msgstr "Napaka pri dodajanju obdelovalnika signala SIGTERM!"

#: ../src/main.c:353
msgid "Failed to add signal handler for SIGINT!"
msgstr "Napaka pri dodajanju obdelovalnika signala SIGINT!"

#: ../src/main.c:357
msgid "Failed to add signal handler for SIGHUP!"
msgstr "Napaka pri dodajanju obdelovalnika signala SIGHUP!"

#. Printed when daemon stops
#: ../src/main.c:363
msgid "Stopping daemon."
msgstr "Zaustavljam demon."

#: ../src/main.c:365
msgid "Daemon initialization and start failed!"
msgstr "Napaka pri inicializaciji in zagonu demona!"

