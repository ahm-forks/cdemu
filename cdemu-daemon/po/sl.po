msgstr "Naprava je zaklenjena!"

#: ../src/daemon.c:255
msgid "CDEmu Daemon"
msgstr "CDEmu demon"

#: ../src/daemon.c:256
msgid "CDEmu Daemon needs to deactivate virtual optical drives"
msgstr "CDEmu demon mora zaustaviti navidezne optične pogone"

#: ../src/daemon.c:345
msgid "Invalid device number!"
msgstr "Neveljavna številka naprave!"

#: ../src/daemon-dbus.c:454
